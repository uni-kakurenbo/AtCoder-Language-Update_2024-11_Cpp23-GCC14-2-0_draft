Name: LibTorch
Description: links LibTorch.
Version:

Cflags: \
    -I/opt/ac_install/libtorch/include/ \
    -I/opt/ac_install/libtorch/include/torch/csrc/api/include/ \

Libs: \
    -L/opt/ac_install/libtorch/lib/ \
    -Wl,-R/opt/ac_install/libtorch/lib/ \
    \
    -ltorch \
    -ltorch_cpu \
    -lc10 \
